{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2022",
      "displayName": "Visual Studio 17 2022",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "environment": {
        "CMAKE_GENERATOR_PLATFORM": null
      }
    },
    {
      "name": "vs2022-debug",
      "displayName": "Visual Studio 17 2022 Debug",
      "inherits": "vs2022",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "xcode",
      "displayName": "Xcode (macOS)",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build"
    }
  ],
  "buildPresets": [
    {
      "name": "vs2022-release",
      "configurePreset": "vs2022",
      "configuration": "Release"
    },
    {
      "name": "vs2022-debug",
      "configurePreset": "vs2022-debug",
      "configuration": "Debug"
    },
    {
      "name": "xcode-release",
      "configurePreset": "xcode",
      "configuration": "Release"
    },
    {
      "name": "xcode-debug",
      "configurePreset": "xcode",
      "configuration": "Debug"
    }
  ]
}
