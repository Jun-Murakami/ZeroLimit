{
  "name": "zerolimit-webui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --config vite.config.web.ts",
    "prebuild": "license-checker --production --json --out src/assets/licenses.json",
    "build": "tsc -b && vite build",
    "build:web": "vite build --config vite.config.web.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:web": "vite preview --config vite.config.web.ts",
    "licenses": "license-checker --production --json --out src/assets/licenses.json"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/jost": "^5.2.8",
    "@fontsource/red-hat-mono": "^5.2.8",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "juce-framework-frontend-mirror": "^8.0.8-rc.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-use": "^17.6.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/node": "^24.7.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.23",
    "globals": "^16.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.0",
    "vite": "^7.1.9",
    "license-checker": "^25.0.1"
  }
}
